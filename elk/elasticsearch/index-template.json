{
  "index_patterns": ["bank-logs-*"],
  "data_stream": {},
  "priority": 500,
  "template": {
    "mappings": {
      "properties": {
        "@timestamp":    { "type": "date" },
        "level":         { "type": "keyword" },
        "service":       { "type": "keyword" },
        "traceId":       { "type": "keyword" },
        "env":           { "type": "keyword" },
        "message":       { "type": "text" },
        "logger":        { "type": "keyword" },
        "http": {
          "properties": {
            "method":         { "type": "keyword" },
            "path":           { "type": "keyword" },
            "status":         { "type": "integer" },
            "responseTimeMs": { "type": "long" },
            "clientIp":       { "type": "ip" }
          }
        },
        "error": {
          "properties": {
            "type":     { "type": "keyword" },
            "category": { "type": "keyword" },
            "severity": { "type": "keyword" },
            "message":  { "type": "text" },
            "stack":    { 
              "type": "text",
              "index": true
            }
          }
        }
      }
    },
    "settings": {
      "index": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "refresh_interval": "5s",
        "mapping.ignore_malformed": true
      }
    }
  }
}
