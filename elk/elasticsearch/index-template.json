{
  "index_patterns": ["bank-logs-*"],
  "template": {
    "mappings": {
      "properties": {
        "timestamp": { "type": "date", "format": "yyyy-MM-dd HH:mm:ss.SSS" },
        "level": { "type": "keyword" },
        "service": { "type": "keyword" },
        "traceId": { "type": "keyword" },
        "message": { "type": "text" },
        "method": { "type": "keyword" },
        "path": { "type": "keyword" },
        "status": { "type": "integer" },
        "durationMs": { "type": "long" },
        "exception": { "type": "text" },
        "stackTrace": { "type": "text" }
      }
    },
    "settings": {
      "index": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "refresh_interval": "5s"
      }
    }
  }
}
