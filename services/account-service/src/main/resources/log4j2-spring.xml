<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Properties>
        <Property name="LOG_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss} [%X{traceId}] %-5p %c{36} - %m%n
        </Property>
    </Properties>

    <Appenders>

        <!-- Console output for IntelliJ -->
        <Console name="CONSOLE" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <RollingFile name="FILE"
                     fileName="logs/account-service.log"
                     filePattern="logs/account-service.%d{yyyy-MM-dd}.log">
            <JsonTemplateLayout>
                <EventTemplateAdditionalField
                        key="service"
                        value="account-service"/>
                <EventTemplateAdditionalField
                        key="app"
                        value="bank-transaction-platform"/>
                <EventTemplateAdditionalField
                        key="traceId"
                        value="${ctx:traceId}"/>
                <EventTemplateAdditionalField
                        key="method"
                        value="${ctx:method}"/>
                <EventTemplateAdditionalField
                        key="path"
                        value="${ctx:path}"/>
                <EventTemplateAdditionalField
                        key="status"
                        value="${ctx:status}"/>
                <EventTemplateAdditionalField
                        key="durationMs"
                        value="${ctx:durationMs}"/>
                <EventTemplateAdditionalField
                        key="ip"
                        value="${ctx:ip}"/>
            </JsonTemplateLayout>
            <Policies>
                <TimeBasedTriggeringPolicy/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>

        <!-- File output for Filebeat (strict JSON format) -->
        <RollingFile name="FILE"
                 fileName="logs/account-service.log"
                 filePattern="logs/account-service.%d{yyyy-MM-dd}.log">
            <JsonLayout compact="true"
                eventEol="true"
                properties="true"
                stacktraceAsString="true"/>
            <Policies>
            <TimeBasedTriggeringPolicy/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="CONSOLE"/>
            <AppenderRef ref="FILE"/>
        </Root>
    </Loggers>

</Configuration>